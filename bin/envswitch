#!/usr/bin/env bash
set -euo pipefail

readonly ENVS_NAME="EnvSwitch"
ENVS_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
readonly ENVS_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/EnvSwitch"
readonly ENVS_LEGACY_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/envswitch"
readonly ENVS_CONFIG_FILE="$ENVS_CONFIG_HOME/config"
readonly ENVS_STATE_FILE="$ENVS_CONFIG_HOME/state"
readonly ENVS_PROFILE_FILE="$ENVS_CONFIG_HOME/profile.sh"
readonly ENVS_LEGACY_PROFILE_FILE="$ENVS_LEGACY_CONFIG_HOME/profile.sh"
readonly ENVS_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}/EnvSwitch"
readonly ENVS_BEGIN="# >>> EnvSwitch >>>"
readonly ENVS_END="# <<< EnvSwitch <<<"
readonly ENVS_LEGACY_BEGIN="# >>> envswitch >>>"
readonly ENVS_LEGACY_END="# <<< envswitch <<<"
readonly ENVS_TUNA_CONDA_FORGE="https://mirrors.tuna.tsinghua.edu.cn/anaconda/cloud/conda-forge"
readonly ENVS_TUNA_NVIDIA_CONDA="https://mirrors.tuna.tsinghua.edu.cn/anaconda/cloud/nvidia"
readonly ENVS_TUNA_CUDA_BASE="https://mirrors.tuna.tsinghua.edu.cn/cuda"
readonly ENVS_NVIDIA_CUDA_CN_BASE="https://developer.download.nvidia.cn/compute/cuda"
readonly ENVS_NVIDIA_CUDA_GLOBAL_BASE="https://developer.download.nvidia.com/compute/cuda"
readonly ENVS_MICROMAMBA_PACKAGE="micromamba-2.8.1-0.tar.bz2"
readonly ENVS_MODULES="gcc cuda python"
readonly ENVS_PYTHON_STANDALONE_RELEASE="20260211"
readonly ENVS_PYTHON_STANDALONE_SHA256="1dbaa624a09e15afe7efbdac08d42993135a68db8d34f986ef6977a6d77bdc3c"

usage() {
    cat <<'USAGE'
EnvSwitch - switch per-user GCC, CUDA toolkit, and Python environments

Usage:
  envswitch install            Install shell hook for current and future terminals
  envswitch uninstall          Remove shell hook and disable EnvSwitch
  envswitch fetch defaults     Download all default versions
  envswitch fetch gcc [ver]    Download GCC; omitted version uses the default
  envswitch fetch cuda [ver]   Download CUDA; omitted version uses the default
  envswitch fetch python [ver] Download Python; omitted version uses the default
  envswitch fetch cuda [ver] --source tuna|official|global
  envswitch fetch cuda [ver] --provider conda
  envswitch link gcc <ver> <path>
  envswitch link cuda <ver> <path>
  envswitch link python <ver> <path>
  envswitch on [tool]          Restore all tools, or enable one tool
  envswitch off [tool]         Disable all tools, or disable one tool
  envswitch status             Show each tool's independent state
  envswitch use gcc [version]  Enable GCC; omitted version uses the default
  envswitch use cuda [version] Enable CUDA; omitted version uses the default
  envswitch use python [ver]   Enable Python; omitted version uses the default
  envswitch default gcc <ver>  Change default GCC version
  envswitch default cuda <ver> Change default CUDA toolkit version
  envswitch default python <ver>
  envswitch help               Show this help

After install, envswitch on/off/use refreshes the current shell and
persists across new terminals and reconnects.
USAGE
}

die() {
    printf 'envswitch: %s\n' "$*" >&2
    exit 1
}

info() {
    printf 'envswitch: %s\n' "$*"
}

ensure_config_dir() {
    mkdir -p "$ENVS_CONFIG_HOME"
}

ensure_cache_dir() {
    mkdir -p "$ENVS_CACHE_HOME/downloads"
}

have_command() {
    command -v "$1" >/dev/null 2>&1
}

normalize_gcc_version() {
    local version="${1#gcc-}"
    [[ "$version" =~ ^[0-9]+$ ]] || die "invalid GCC version: $1"
    printf '%s\n' "$version"
}

normalize_cuda_version() {
    local version="${1#cuda-}"
    [[ "$version" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "invalid CUDA toolkit version: $1"
    printf '%s\n' "$version"
}

normalize_python_version() {
    local version="${1#python-}"
    [[ "$version" =~ ^[0-9]+[.][0-9]+[.][0-9]+$ ]] || die "invalid Python version: $1"
    printf '%s\n' "$version"
}

gcc_home_for() {
    local version
    version="$(normalize_gcc_version "$1")"
    printf '%s/modules/gcc/versions/gcc-%s\n' "$ENVS_ROOT" "$version"
}

python_home_for() {
    local version
    version="$(normalize_python_version "$1")"
    printf '%s/modules/python/versions/python-%s\n' "$ENVS_ROOT" "$version"
}

cuda_home_for() {
    local version
    version="$(normalize_cuda_version "$1")"
    printf '%s/modules/cuda/versions/cuda-%s\n' "$ENVS_ROOT" "$version"
}

assert_gcc_exists() {
    local home="$1"
    [[ -d "$home" ]] || die "GCC version not found: $home. Run: envswitch fetch gcc ${home##*gcc-}"
    [[ -x "$home/bin/x86_64-conda-linux-gnu-gcc" ]] || die "GCC compiler missing in: $home"
    [[ -x "$home/bin/x86_64-conda-linux-gnu-g++" ]] || die "G++ compiler missing in: $home"
}

assert_cuda_exists() {
    local home="$1"
    [[ -d "$home" ]] || die "CUDA toolkit version not found: $home. Run: envswitch fetch cuda ${home##*cuda-}"
    [[ -x "$home/bin/nvcc" ]] || die "CUDA nvcc missing in: $home. Run: envswitch fetch cuda ${home##*cuda-}"
}

assert_python_exists() {
    local home="$1"
    [[ -d "$home" ]] || die "Python version not found: $home. Run: envswitch fetch python ${home##*python-}"
    [[ -x "$home/bin/python3" ]] || die "Python executable missing in: $home"
}

default_from_symlink() {
    local module="$1"
    local link="$ENVS_ROOT/modules/$module/default"
    if [[ -L "$link" ]]; then
        basename -- "$(readlink -- "$link")" | sed "s/^$module-//"
    else
        case "$module" in
            gcc) printf '12\n' ;;
            cuda) printf '12.8\n' ;;
            python) printf '3.12.12\n' ;;
            *) return 1 ;;
        esac
    fi
}

load_config() {
    local runtime_root="$ENVS_ROOT"
    ENVS_DEFAULT_GCC_VERSION="$(default_from_symlink gcc)"
    ENVS_DEFAULT_CUDA_VERSION="$(default_from_symlink cuda)"
    ENVS_DEFAULT_PYTHON_VERSION="$(default_from_symlink python)"

    if [[ -r "$ENVS_CONFIG_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$ENVS_CONFIG_FILE"
    elif [[ -r "$ENVS_LEGACY_CONFIG_HOME/config" ]]; then
        # shellcheck disable=SC1090
        source "$ENVS_LEGACY_CONFIG_HOME/config"
    fi

    ENVS_DEFAULT_GCC_VERSION="${ENVS_DEFAULT_GCC_VERSION:-${ENVSWITCH_DEFAULT_GCC_VERSION:-12}}"
    ENVS_DEFAULT_CUDA_VERSION="${ENVS_DEFAULT_CUDA_VERSION:-${ENVSWITCH_DEFAULT_CUDA_VERSION:-12.8}}"
    ENVS_DEFAULT_PYTHON_VERSION="${ENVS_DEFAULT_PYTHON_VERSION:-3.12.12}"

    ENVS_ROOT="$runtime_root"
}

load_state() {
    ENVS_STATE_VERSION=''
    ENVS_GCC_ENABLED=''
    ENVS_GCC_VERSION=''
    ENVS_CUDA_ENABLED=''
    ENVS_CUDA_VERSION=''
    ENVS_PYTHON_ENABLED=''
    ENVS_PYTHON_VERSION=''
    ENVS_LAST_ENABLED_MODULES=''
    ENVS_ENABLED=''

    if [[ -r "$ENVS_STATE_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$ENVS_STATE_FILE"
    elif [[ -r "$ENVS_LEGACY_CONFIG_HOME/state" ]]; then
        # shellcheck disable=SC1090
        source "$ENVS_LEGACY_CONFIG_HOME/state"
    fi

    if [[ "${ENVS_STATE_VERSION:-}" != "2" ]]; then
        local legacy_enabled="${ENVS_ENABLED:-${ENVSWITCH_ENABLED:-0}}"
        ENVS_GCC_ENABLED="${ENVS_GCC_ENABLED:-$legacy_enabled}"
        ENVS_CUDA_ENABLED="${ENVS_CUDA_ENABLED:-$legacy_enabled}"
        ENVS_PYTHON_ENABLED="${ENVS_PYTHON_ENABLED:-0}"
        if [[ "$legacy_enabled" == "1" ]]; then
            ENVS_LAST_ENABLED_MODULES="${ENVS_LAST_ENABLED_MODULES:-gcc cuda}"
        fi
    fi

    ENVS_STATE_VERSION='2'
    ENVS_GCC_ENABLED="${ENVS_GCC_ENABLED:-0}"
    ENVS_GCC_VERSION="${ENVS_GCC_VERSION:-${ENVSWITCH_GCC_VERSION:-$ENVS_DEFAULT_GCC_VERSION}}"
    ENVS_CUDA_ENABLED="${ENVS_CUDA_ENABLED:-0}"
    ENVS_CUDA_VERSION="${ENVS_CUDA_VERSION:-${ENVSWITCH_CUDA_VERSION:-$ENVS_DEFAULT_CUDA_VERSION}}"
    ENVS_PYTHON_ENABLED="${ENVS_PYTHON_ENABLED:-0}"
    ENVS_PYTHON_VERSION="${ENVS_PYTHON_VERSION:-$ENVS_DEFAULT_PYTHON_VERSION}"
    ENVS_LAST_ENABLED_MODULES="${ENVS_LAST_ENABLED_MODULES:-}"
}

write_config() {
    ensure_config_dir
    cat >"$ENVS_CONFIG_FILE" <<EOF
ENVS_ROOT='$ENVS_ROOT'
ENVS_DEFAULT_GCC_VERSION='${ENVS_DEFAULT_GCC_VERSION:-12}'
ENVS_DEFAULT_CUDA_VERSION='${ENVS_DEFAULT_CUDA_VERSION:-12.8}'
ENVS_DEFAULT_PYTHON_VERSION='${ENVS_DEFAULT_PYTHON_VERSION:-3.12.12}'
EOF
}

write_state() {
    ensure_config_dir
    cat >"$ENVS_STATE_FILE" <<EOF
ENVS_STATE_VERSION='2'
ENVS_GCC_ENABLED='${ENVS_GCC_ENABLED:-0}'
ENVS_GCC_VERSION='${ENVS_GCC_VERSION:-${ENVS_DEFAULT_GCC_VERSION:-12}}'
ENVS_CUDA_ENABLED='${ENVS_CUDA_ENABLED:-0}'
ENVS_CUDA_VERSION='${ENVS_CUDA_VERSION:-${ENVS_DEFAULT_CUDA_VERSION:-12.8}}'
ENVS_PYTHON_ENABLED='${ENVS_PYTHON_ENABLED:-0}'
ENVS_PYTHON_VERSION='${ENVS_PYTHON_VERSION:-${ENVS_DEFAULT_PYTHON_VERSION:-3.12.12}}'
ENVS_LAST_ENABLED_MODULES='${ENVS_LAST_ENABLED_MODULES:-}'
EOF
}

normalize_module_version() {
    local module="$1"
    local version="$2"
    case "$module" in
        gcc) normalize_gcc_version "$version" ;;
        cuda) normalize_cuda_version "$version" ;;
        python) normalize_python_version "$version" ;;
        *) die "unknown module: $module" ;;
    esac
}

module_default_version() {
    case "$1" in
        gcc) printf '%s\n' "$ENVS_DEFAULT_GCC_VERSION" ;;
        cuda) printf '%s\n' "$ENVS_DEFAULT_CUDA_VERSION" ;;
        python) printf '%s\n' "$ENVS_DEFAULT_PYTHON_VERSION" ;;
        *) die "unknown module: $1" ;;
    esac
}

module_home_for() {
    local module="$1"
    local version="$2"
    case "$module" in
        gcc) gcc_home_for "$version" ;;
        cuda) cuda_home_for "$version" ;;
        python) python_home_for "$version" ;;
        *) die "unknown module: $module" ;;
    esac
}

assert_module_exists() {
    local module="$1"
    local home="$2"
    case "$module" in
        gcc) assert_gcc_exists "$home" ;;
        cuda) assert_cuda_exists "$home" ;;
        python) assert_python_exists "$home" ;;
        *) die "unknown module: $module" ;;
    esac
}

module_is_installed() {
    local module="$1"
    local home="$2"
    case "$module" in
        gcc) [[ -x "$home/bin/x86_64-conda-linux-gnu-gcc" && -x "$home/bin/x86_64-conda-linux-gnu-g++" ]] ;;
        cuda) [[ -x "$home/bin/nvcc" ]] ;;
        python) [[ -x "$home/bin/python3" ]] ;;
        *) return 1 ;;
    esac
}

module_enabled() {
    case "$1" in
        gcc) [[ "$ENVS_GCC_ENABLED" == "1" ]] ;;
        cuda) [[ "$ENVS_CUDA_ENABLED" == "1" ]] ;;
        python) [[ "$ENVS_PYTHON_ENABLED" == "1" ]] ;;
        *) return 1 ;;
    esac
}

module_set_enabled() {
    local module="$1"
    local value="$2"
    case "$module" in
        gcc) ENVS_GCC_ENABLED="$value" ;;
        cuda) ENVS_CUDA_ENABLED="$value" ;;
        python) ENVS_PYTHON_ENABLED="$value" ;;
        *) die "unknown module: $module" ;;
    esac
}

module_selected_version() {
    case "$1" in
        gcc) printf '%s\n' "$ENVS_GCC_VERSION" ;;
        cuda) printf '%s\n' "$ENVS_CUDA_VERSION" ;;
        python) printf '%s\n' "$ENVS_PYTHON_VERSION" ;;
        *) die "unknown module: $1" ;;
    esac
}

module_set_version() {
    local module="$1"
    local version="$2"
    case "$module" in
        gcc) ENVS_GCC_VERSION="$version" ;;
        cuda) ENVS_CUDA_VERSION="$version" ;;
        python) ENVS_PYTHON_VERSION="$version" ;;
        *) die "unknown module: $module" ;;
    esac
}

current_enabled_modules() {
    local module
    local enabled=""
    for module in $ENVS_MODULES; do
        if module_enabled "$module"; then
            enabled="${enabled:+$enabled }$module"
        fi
    done
    printf '%s\n' "$enabled"
}

write_profile() {
    ensure_config_dir
    cat >"$ENVS_PROFILE_FILE" <<'PROFILE'
# This file is generated by EnvSwitch. Do not edit by hand.

export ENVS_SHELL_HOOK_ACTIVE=1

__envswitch_remove_path_entries() {
    local var_name="$1"
    local current="${!var_name:-}"
    local cleaned=""
    local entry

    if [ -z "$current" ]; then
        export "$var_name="
        return 0
    fi

    local old_ifs="$IFS"
    IFS=':'
    for entry in $current; do
        case "$entry" in
            "$ENVS_ROOT"/modules/gcc/versions/* | \
            "$ENVS_ROOT"/modules/gcc/versions/*/bin | \
            "$ENVS_ROOT"/modules/gcc/versions/*/lib | \
            "$ENVS_ROOT"/modules/gcc/versions/*/lib64 | \
            "$ENVS_ROOT"/modules/gcc/versions/*/lib/pkgconfig | \
            "$ENVS_ROOT"/modules/gcc/versions/*/lib64/pkgconfig | \
            "$ENVS_ROOT"/modules/gcc/versions/*/share/pkgconfig | \
            "$ENVS_ROOT"/modules/gcc/versions/*/x86_64-conda-linux-gnu/lib | \
            "$ENVS_ROOT"/modules/gcc/versions/*/x86_64-conda-linux-gnu/lib/pkgconfig | \
            "$ENVS_ROOT"/modules/gcc/versions/*/x86_64-conda-linux-gnu/sysroot/lib | \
            "$ENVS_ROOT"/modules/gcc/versions/*/x86_64-conda-linux-gnu/sysroot/lib64 | \
            "$ENVS_ROOT"/modules/gcc/versions/*/x86_64-conda-linux-gnu/sysroot/usr/lib | \
            "$ENVS_ROOT"/modules/cuda/versions/*/bin | \
            "$ENVS_ROOT"/modules/cuda/versions/*/lib64 | \
            "$ENVS_ROOT"/modules/cuda/versions/*/extras/CUPTI/lib64 | \
            "$ENVS_ROOT"/modules/python/versions/* | \
            "$ENVS_ROOT"/modules/python/versions/*/bin | \
            "$ENVS_LEGACY_ROOT"/modules/* | \
            "$ENVS_LEGACY_ROOT"/modules/*/* | \
            "$ENVS_LEGACY_ROOT"/modules/*/*/* | \
            "$ENVS_LEGACY_ROOT"/modules/*/*/*/* | \
            "$ENVS_LEGACY_ROOT"/modules/*/*/*/*/* | \
            "") ;;
            *)
                if [ -z "$cleaned" ]; then
                    cleaned="$entry"
                else
                    cleaned="$cleaned:$entry"
                fi
                ;;
        esac
    done
    IFS="$old_ifs"
    export "$var_name=$cleaned"
}

__envswitch_prepend_path() {
    local var_name="$1"
    local entry="$2"
    [ -d "$entry" ] || return 0

    local current="${!var_name:-}"
    case ":$current:" in
        *":$entry:"*) ;;
        *) export "$var_name=$entry${current:+:$current}" ;;
    esac
}

__envswitch_clear_exports() {
    __envswitch_remove_path_entries PATH
    __envswitch_remove_path_entries LD_LIBRARY_PATH
    __envswitch_remove_path_entries LIBRARY_PATH
    __envswitch_remove_path_entries PKG_CONFIG_PATH
    __envswitch_remove_path_entries CMAKE_PREFIX_PATH

    __envswitch_unset_if_managed() {
        local var_name="$1"
        local value="${!var_name:-}"
        case "$value" in
            "$ENVS_ROOT"/modules/* | "$ENVS_LEGACY_ROOT"/modules/*) unset "$var_name" ;;
        esac
    }

    __envswitch_unset_if_contains_root() {
        local var_name="$1"
        local value="${!var_name:-}"
        case "$value" in
            *"$ENVS_ROOT"/modules/* | *"$ENVS_LEGACY_ROOT"/modules/*) unset "$var_name" ;;
        esac
    }

    unset ENVS_TOOLCHAIN_ROOT
    unset ENVS_GCC_HOME
    unset ENVS_CUDA_HOME
    unset ENVS_PYTHON_HOME
    unset TOOLCHAIN_ROOT
    unset ENVSWITCH_ROOT
    unset ENVSWITCH_TOOLCHAIN_ROOT
    unset ENVSWITCH_GCC_HOME
    unset ENVSWITCH_CUDA_HOME
    unset ENVSWITCH_PYTHON_HOME
    unset ENVSWITCH_SHELL_HOOK_ACTIVE
    __envswitch_unset_if_managed CUDA_HOME
    __envswitch_unset_if_managed CUDA_PATH
    __envswitch_unset_if_managed CC
    __envswitch_unset_if_managed CXX
    __envswitch_unset_if_managed CMAKE_C_COMPILER
    __envswitch_unset_if_managed CMAKE_CXX_COMPILER
    __envswitch_unset_if_contains_root CMAKE_ARGS
    unset -f __envswitch_unset_if_managed
    unset -f __envswitch_unset_if_contains_root
}

__envswitch_apply() {
    local config_home="${XDG_CONFIG_HOME:-$HOME/.config}/EnvSwitch"
    local config_file="$config_home/config"
    local state_file="$config_home/state"

    [ -r "$config_file" ] || return 0
    # shellcheck disable=SC1090
    . "$config_file"
    [ -n "${ENVS_ROOT:-}" ] || return 0
    ENVS_LEGACY_ROOT="${ENVS_LEGACY_ROOT:-${ENVS_ROOT%/EnvSwitch}/envswitch}"

    __envswitch_clear_exports

    [ -r "$state_file" ] || return 0
    # shellcheck disable=SC1090
    . "$state_file"

    if [ "${ENVS_STATE_VERSION:-}" != "2" ]; then
        local legacy_enabled="${ENVS_ENABLED:-0}"
        ENVS_GCC_ENABLED="${ENVS_GCC_ENABLED:-$legacy_enabled}"
        ENVS_CUDA_ENABLED="${ENVS_CUDA_ENABLED:-$legacy_enabled}"
        ENVS_PYTHON_ENABLED="${ENVS_PYTHON_ENABLED:-0}"
    fi

    local gcc_version="${ENVS_GCC_VERSION:-${ENVS_DEFAULT_GCC_VERSION:-12}}"
    local cuda_version="${ENVS_CUDA_VERSION:-${ENVS_DEFAULT_CUDA_VERSION:-12.8}}"
    local python_version="${ENVS_PYTHON_VERSION:-${ENVS_DEFAULT_PYTHON_VERSION:-3.12.12}}"
    local gcc_home="$ENVS_ROOT/modules/gcc/versions/gcc-$gcc_version"
    local cuda_home="$ENVS_ROOT/modules/cuda/versions/cuda-$cuda_version"
    local python_home="$ENVS_ROOT/modules/python/versions/python-$python_version"

    if [ "${ENVS_GCC_ENABLED:-0}" = "1" ] && [ -d "$gcc_home" ]; then
        export ENVS_TOOLCHAIN_ROOT="$gcc_home"
        export ENVS_GCC_HOME="$gcc_home"
        __envswitch_prepend_path PATH "$gcc_home/bin"
        __envswitch_prepend_path LIBRARY_PATH "$gcc_home/x86_64-conda-linux-gnu/sysroot/usr/lib"
        __envswitch_prepend_path LIBRARY_PATH "$gcc_home/x86_64-conda-linux-gnu/sysroot/lib64"
        __envswitch_prepend_path LIBRARY_PATH "$gcc_home/x86_64-conda-linux-gnu/sysroot/lib"
        __envswitch_prepend_path LIBRARY_PATH "$gcc_home/x86_64-conda-linux-gnu/lib"
        __envswitch_prepend_path LIBRARY_PATH "$gcc_home/lib64"
        __envswitch_prepend_path LIBRARY_PATH "$gcc_home/lib"
        __envswitch_prepend_path PKG_CONFIG_PATH "$gcc_home/x86_64-conda-linux-gnu/lib/pkgconfig"
        __envswitch_prepend_path PKG_CONFIG_PATH "$gcc_home/share/pkgconfig"
        __envswitch_prepend_path PKG_CONFIG_PATH "$gcc_home/lib64/pkgconfig"
        __envswitch_prepend_path PKG_CONFIG_PATH "$gcc_home/lib/pkgconfig"
        __envswitch_prepend_path CMAKE_PREFIX_PATH "$gcc_home"
        export CC="$gcc_home/bin/x86_64-conda-linux-gnu-gcc"
        export CXX="$gcc_home/bin/x86_64-conda-linux-gnu-g++"
        export CMAKE_C_COMPILER="$CC"
        export CMAKE_CXX_COMPILER="$CXX"
        export CMAKE_ARGS="-DCMAKE_C_COMPILER=$CC -DCMAKE_CXX_COMPILER=$CXX"
    fi

    if [ "${ENVS_CUDA_ENABLED:-0}" = "1" ] && [ -d "$cuda_home" ]; then
        export ENVS_CUDA_HOME="$cuda_home"
        export CUDA_HOME="$cuda_home"
        export CUDA_PATH="$cuda_home"
        __envswitch_prepend_path PATH "$cuda_home/bin"
        __envswitch_prepend_path LD_LIBRARY_PATH "$cuda_home/extras/CUPTI/lib64"
        __envswitch_prepend_path LD_LIBRARY_PATH "$cuda_home/lib64"
    fi

    if [ "${ENVS_PYTHON_ENABLED:-0}" = "1" ] && [ -d "$python_home" ]; then
        export ENVS_PYTHON_HOME="$python_home"
        __envswitch_prepend_path PATH "$python_home/bin"
    fi
}

__envswitch_apply

envswitch() {
    ENVS_SHELL_HOOK_ACTIVE=1 command envswitch "$@"
    local rc=$?
    case "${1:-}" in
        on | off | use | default | install | install-shell | fetch | link)
            [ -r "${XDG_CONFIG_HOME:-$HOME/.config}/EnvSwitch/profile.sh" ] && \
                . "${XDG_CONFIG_HOME:-$HOME/.config}/EnvSwitch/profile.sh"
            ;;
        uninstall | uninstall-shell)
            if [ -r "${XDG_CONFIG_HOME:-$HOME/.config}/EnvSwitch/profile.sh" ]; then
                . "${XDG_CONFIG_HOME:-$HOME/.config}/EnvSwitch/profile.sh"
            elif [ "$(type -t __envswitch_clear_exports 2>/dev/null)" = "function" ]; then
                __envswitch_clear_exports
            fi
            ;;
    esac
    return "$rc"
}
PROFILE
}

shell_files() {
    printf '%s\n' "$HOME/.bashrc"
    local zshrc
    if [[ -n "${ZDOTDIR:-}" ]]; then
        zshrc="$ZDOTDIR/.zshrc"
    else
        zshrc="$HOME/.zshrc"
    fi
    if [[ -f "$zshrc" || "${SHELL:-}" == */zsh ]]; then
        printf '%s\n' "$zshrc"
    fi
}

hook_block() {
    cat <<EOF
$ENVS_BEGIN
export PATH="$ENVS_ROOT/bin:\$PATH"
[ -r "$ENVS_PROFILE_FILE" ] && source "$ENVS_PROFILE_FILE"
$ENVS_END
EOF
}

install_hook_in_file() {
    local file="$1"
    local tmp block
    tmp="$(mktemp)"
    block="$(hook_block)"
    awk -v block="$block" '
        inserted != 1 && ($0 ~ /^# If not running interactively/ || $0 ~ /^case \$- in/) {
            print block
            print ""
            inserted = 1
        }
        { print }
        END {
            if (inserted != 1) {
                print ""
                print block
            }
        }
    ' "$file" >"$tmp"
    mv "$tmp" "$file"
}

remove_hook_from_file() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    local tmp
    tmp="$(mktemp)"
    awk \
        -v begin="$ENVS_BEGIN" \
        -v end="$ENVS_END" \
        -v legacy_begin="$ENVS_LEGACY_BEGIN" \
        -v legacy_end="$ENVS_LEGACY_END" '
        $0 == begin || $0 == legacy_begin { skipping = 1; next }
        $0 == end || $0 == legacy_end { skipping = 0; next }
        skipping != 1 { print }
    ' "$file" >"$tmp"
    mv "$tmp" "$file"
}

remove_legacy_hook_from_file() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    local tmp
    tmp="$(mktemp)"
    grep -vE "^[[:space:]]*(source|\\.)[[:space:]]+($HOME/tools/(toolchains|envswitch|EnvSwitch)|$ENVS_ROOT)/(scripts|legacy-scripts)/use-default-gcc[.]sh[[:space:]]*$" "$file" >"$tmp" || true
    mv "$tmp" "$file"
}

remove_legacy_source_wrapper_from_file() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    local tmp
    tmp="$(mktemp)"
    awk '
        /^# Keep the default compiler toolchain stable after manual `source \.\.\.`\.$/ {
            skipping = 1
            depth = 0
            next
        }
        skipping == 1 {
            if ($0 ~ /^source\(\)[[:space:]]*\{/) {
                depth = 1
                next
            }
            if (depth > 0 && $0 ~ /^\}/) {
                skipping = 0
                depth = 0
                next
            }
            next
        }
        { print }
    ' "$file" >"$tmp"
    mv "$tmp" "$file"
}

install_shell() {
    load_config
    load_state
    write_config
    write_state
    write_profile
    rm -f "$ENVS_LEGACY_PROFILE_FILE"

    local file
    while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        [[ -f "$file" ]] || touch "$file"
        remove_hook_from_file "$file"
        remove_legacy_hook_from_file "$file"
        remove_legacy_source_wrapper_from_file "$file"
        install_hook_in_file "$file"
        info "installed shell hook: $file"
    done < <(shell_files)

    info "run 'source ~/.bashrc' or open a new terminal to use 'envswitch' directly"
}

uninstall_shell() {
    load_config
    load_state

    local file
    while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        remove_hook_from_file "$file"
        remove_legacy_hook_from_file "$file"
        remove_legacy_source_wrapper_from_file "$file"
        info "removed shell hook: $file"
    done < <(shell_files)

    ENVS_LAST_ENABLED_MODULES="$(current_enabled_modules)"
    ENVS_GCC_ENABLED=0
    ENVS_CUDA_ENABLED=0
    ENVS_PYTHON_ENABLED=0
    write_state
    rm -f "$ENVS_PROFILE_FILE" "$ENVS_LEGACY_PROFILE_FILE"
    info "disabled EnvSwitch"
}

install_with_micromamba() {
    local prefix="$1"
    shift
    micromamba create -y -p "$prefix" --override-channels "$@"
}

install_with_mamba() {
    local prefix="$1"
    shift
    mamba create -y -p "$prefix" --override-channels "$@"
}

install_with_conda() {
    local prefix="$1"
    shift
    conda create -y -p "$prefix" --override-channels "$@"
}

envswitch_micromamba() {
    printf '%s/bin/micromamba\n' "$ENVS_CACHE_HOME"
}

is_empty_dir() {
    local dir="$1"
    [[ -d "$dir" ]] || return 1
    [[ -z "$(find "$dir" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]]
}

bootstrap_micromamba() {
    local micromamba
    local package
    local url
    local extract_dir

    micromamba="$(envswitch_micromamba)"
    if [[ -x "$micromamba" ]]; then
        info "using bundled micromamba: $micromamba"
        return 0
    fi

    package="$ENVS_CACHE_HOME/downloads/$ENVS_MICROMAMBA_PACKAGE"
    url="$ENVS_TUNA_CONDA_FORGE/linux-64/$ENVS_MICROMAMBA_PACKAGE"
    extract_dir="$ENVS_CACHE_HOME/micromamba-bootstrap"

    download_file "$url" "$package"

    rm -rf "$extract_dir"
    mkdir -p "$extract_dir" "$ENVS_CACHE_HOME/bin"
    tar -xjf "$package" -C "$extract_dir" bin/micromamba

    if [[ ! -x "$extract_dir/bin/micromamba" ]]; then
        rm -rf "$extract_dir"
        die "micromamba package did not contain bin/micromamba"
    fi

    mv "$extract_dir/bin/micromamba" "$micromamba"
    chmod +x "$micromamba"
    rm -rf "$extract_dir"

    info "bootstrapped micromamba: $micromamba"
}

install_conda_prefix() {
    local prefix="$1"
    shift

    if is_empty_dir "$prefix"; then
        rmdir "$prefix"
    fi

    mkdir -p "$(dirname -- "$prefix")"

    if have_command micromamba; then
        install_with_micromamba "$prefix" "$@"
    elif have_command mamba; then
        install_with_mamba "$prefix" "$@"
    elif have_command conda; then
        install_with_conda "$prefix" "$@"
    else
        bootstrap_micromamba
        "$(envswitch_micromamba)" create -y -p "$prefix" --override-channels "$@"
    fi
}

download_file() {
    local url="$1"
    local dest="$2"
    local tmp="${dest}.tmp.$$"

    ensure_cache_dir

    if [[ -s "$dest" ]]; then
        info "using cached download: $dest"
        return 0
    fi

    rm -f "$tmp"
    info "downloading: $url"
    if have_command curl; then
        curl -fL --retry 3 --connect-timeout 20 -o "$tmp" "$url"
    elif have_command wget; then
        wget -O "$tmp" "$url"
    else
        die "no downloader found. Install curl or wget, then retry."
    fi

    mv "$tmp" "$dest"
}

sha256_file() {
    local file="$1"
    if have_command sha256sum; then
        sha256sum "$file" | awk '{print $1}'
    elif have_command shasum; then
        shasum -a 256 "$file" | awk '{print $1}'
    else
        die "no SHA256 tool found. Install sha256sum or shasum, then retry."
    fi
}

verify_sha256() {
    local file="$1"
    local expected="$2"
    local actual
    actual="$(sha256_file "$file")"
    if [[ "$actual" != "$expected" ]]; then
        rm -f "$file"
        die "SHA256 mismatch for $file: expected $expected, got $actual"
    fi
}

cuda_runfile_path_for() {
    local version="$1"
    case "$version" in
        12.8) printf '%s\n' '12.8.0/local_installers/cuda_12.8.0_570.86.10_linux.run' ;;
        *) die "no NVIDIA runfile is configured for CUDA toolkit $version" ;;
    esac
}

cuda_runfile_url_for() {
    local version="$1"
    local source="$2"
    local base path

    path="$(cuda_runfile_path_for "$version")"
    case "$source" in
        tuna | tsinghua)
            base="$ENVS_TUNA_CUDA_BASE"
            ;;
        official | nvidia | nvidia-cn | cn)
            base="$ENVS_NVIDIA_CUDA_CN_BASE"
            ;;
        global | official-global | nvidia-global)
            base="$ENVS_NVIDIA_CUDA_GLOBAL_BASE"
            ;;
        *)
            die "unknown CUDA source: $source. Supported: official, global, tuna"
            ;;
    esac

    printf '%s/%s\n' "${base%/}" "$path"
}

cuda_runfile_name_for() {
    local version="$1"
    basename -- "$(cuda_runfile_path_for "$version")"
}

ensure_install_target_available() {
    local prefix="$1"
    local kind="$2"

    if [[ -L "$prefix" ]]; then
        die "$kind target is already a symlink: $prefix"
    fi

    if [[ -d "$prefix" ]] && ! is_empty_dir "$prefix"; then
        die "target exists but does not look like a complete $kind install: $prefix"
    fi
}

install_cuda_with_runfile() {
    local version="$1"
    local prefix="$2"
    local source="$3"
    local runfile="${4:-}"
    local filename staging tmpdir url

    if [[ -z "$runfile" ]]; then
        filename="$(cuda_runfile_name_for "$version")"
        runfile="$ENVS_CACHE_HOME/downloads/$filename"
        url="$(cuda_runfile_url_for "$version" "$source")"
        download_file "$url" "$runfile"
    else
        [[ -f "$runfile" ]] || die "CUDA runfile not found: $runfile"
    fi

    ensure_install_target_available "$prefix" "CUDA toolkit"

    staging="${prefix}.installing.$$"
    tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/EnvSwitch-cuda.XXXXXX")"
    rm -rf "$staging"
    mkdir -p "$(dirname -- "$prefix")" "$staging"

    info "installing CUDA toolkit $version from NVIDIA runfile"
    info "this can take several minutes while the 5GB+ toolkit is unpacked"
    sh "$runfile" --silent --toolkit --toolkitpath="$staging" --override --tmpdir="$tmpdir" &
    local installer_pid="$!"
    local elapsed=0
    local size

    while kill -0 "$installer_pid" 2>/dev/null; do
        sleep 15
        elapsed=$((elapsed + 15))
        if [[ -d "$staging" ]]; then
            size="$(du -sh "$staging" 2>/dev/null | awk '{print $1}')"
            info "still installing CUDA toolkit... elapsed=${elapsed}s size=${size:-unknown}"
        else
            info "still installing CUDA toolkit... elapsed=${elapsed}s"
        fi
    done

    if ! wait "$installer_pid"; then
        rm -rf "$staging" "$tmpdir"
        die "CUDA runfile installer failed"
    fi
    rm -rf "$tmpdir"

    if [[ ! -x "$staging/bin/nvcc" ]]; then
        rm -rf "$staging"
        die "CUDA runfile completed but nvcc was not installed"
    fi

    if is_empty_dir "$prefix"; then
        rmdir "$prefix"
    fi
    mv "$staging" "$prefix"
}

install_gcc() {
    local version="${1:-}"
    [[ -n "$version" ]] || die "usage: envswitch fetch gcc <version>"
    version="$(normalize_gcc_version "$version")"

    case "$version" in
        11 | 12 | 14) ;;
        *) die "unsupported GCC version: $version. Supported: 11, 12, 14" ;;
    esac

    local prefix
    prefix="$(gcc_home_for "$version")"

    if [[ -x "$prefix/bin/x86_64-conda-linux-gnu-gcc" && -x "$prefix/bin/x86_64-conda-linux-gnu-g++" ]]; then
        ensure_gcc_command_shims "$prefix"
        info "gcc-$version already installed: $prefix"
        return 0
    fi

    if [[ -d "$prefix" ]] && ! is_empty_dir "$prefix"; then
        die "target exists but does not look like a complete GCC install: $prefix"
    fi

    install_conda_prefix \
        "$prefix" \
        -c "$ENVS_TUNA_CONDA_FORGE" \
        "gcc_linux-64=${version}.*" \
        "gxx_linux-64=${version}.*" \
        cmake \
        make \
        ninja \
        pkg-config
    ensure_gcc_command_shims "$prefix"
    info "installed gcc-$version: $prefix"
}

ensure_gcc_command_shims() {
    local prefix="$1"
    local bin="$prefix/bin"

    [[ -d "$bin" ]] || return 0
    [[ "$prefix" == "$ENVS_ROOT"/modules/gcc/versions/gcc-* ]] || return 0
    [[ ! -L "$prefix" ]] || return 0

    if [[ ! -e "$bin/gcc" && -x "$bin/x86_64-conda-linux-gnu-gcc" ]]; then
        ln -s x86_64-conda-linux-gnu-gcc "$bin/gcc"
    fi
    if [[ ! -e "$bin/g++" && -x "$bin/x86_64-conda-linux-gnu-g++" ]]; then
        ln -s x86_64-conda-linux-gnu-g++ "$bin/g++"
    fi
    if [[ ! -e "$bin/cc" && -x "$bin/x86_64-conda-linux-gnu-gcc" ]]; then
        ln -s x86_64-conda-linux-gnu-gcc "$bin/cc"
    fi
    if [[ ! -e "$bin/c++" && -x "$bin/x86_64-conda-linux-gnu-g++" ]]; then
        ln -s x86_64-conda-linux-gnu-g++ "$bin/c++"
    fi
}

install_cuda() {
    local version="${1:-}"
    [[ -n "$version" ]] || die "usage: envswitch fetch cuda <version>"
    version="$(normalize_cuda_version "$version")"
    shift || true

    local provider="nvidia-runfile"
    local source="official"
    local runfile=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --provider)
                [[ -n "${2:-}" ]] || die "usage: envswitch fetch cuda <version> --provider <nvidia-runfile|conda>"
                provider="$2"
                shift 2
                ;;
            --provider=*)
                provider="${1#--provider=}"
                shift
                ;;
            --source)
                [[ -n "${2:-}" ]] || die "usage: envswitch fetch cuda <version> --source <official|global|tuna>"
                source="$2"
                shift 2
                ;;
            --source=*)
                source="${1#--source=}"
                shift
                ;;
            --runfile)
                [[ -n "${2:-}" ]] || die "usage: envswitch fetch cuda <version> --runfile <path>"
                runfile="$2"
                shift 2
                ;;
            --runfile=*)
                runfile="${1#--runfile=}"
                shift
                ;;
            --conda)
                provider="conda"
                shift
                ;;
            --nvidia-runfile | --runfile-provider)
                provider="nvidia-runfile"
                shift
                ;;
            *)
                die "unknown CUDA fetch option: $1"
                ;;
        esac
    done

    case "$version" in
        12.8) ;;
        *) die "unsupported CUDA toolkit version: $version. Supported: 12.8" ;;
    esac

    local prefix
    prefix="$(cuda_home_for "$version")"

    if [[ -x "$prefix/bin/nvcc" ]]; then
        info "cuda-$version already installed: $prefix"
        return 0
    fi

    case "$provider" in
        nvidia-runfile | runfile | nvidia)
            install_cuda_with_runfile "$version" "$prefix" "$source" "$runfile"
            ;;
        conda)
            ensure_install_target_available "$prefix" "CUDA toolkit"
            install_conda_prefix \
                "$prefix" \
                -c "$ENVS_TUNA_NVIDIA_CONDA" \
                -c "$ENVS_TUNA_CONDA_FORGE" \
                "cuda-toolkit=${version}"
            ;;
        *)
            die "unknown CUDA provider: $provider. Supported: nvidia-runfile, conda"
            ;;
    esac
    info "installed cuda-$version: $prefix"
}

python_standalone_asset_name_for() {
    local version="$1"
    case "$(uname -s):$(uname -m):$version" in
        Linux:x86_64:3.12.12)
            printf 'cpython-3.12.12+%s-x86_64-unknown-linux-gnu-install_only_stripped.tar.gz\n' \
                "$ENVS_PYTHON_STANDALONE_RELEASE"
            ;;
        Linux:*:3.12.12)
            die "Python $version standalone install currently supports Linux x86_64 only"
            ;;
        *)
            die "unsupported Python version or platform: $version on $(uname -s) $(uname -m)"
            ;;
    esac
}

python_standalone_url_for() {
    local version="$1"
    local asset
    asset="$(python_standalone_asset_name_for "$version")"
    printf 'https://github.com/astral-sh/python-build-standalone/releases/download/%s/%s\n' \
        "$ENVS_PYTHON_STANDALONE_RELEASE" \
        "${asset/+/%2B}"
}

ensure_python_command_shims() {
    local prefix="$1"
    local bin="$prefix/bin"

    [[ -d "$bin" ]] || return 0
    [[ "$prefix" == "$ENVS_ROOT"/modules/python/versions/python-* ]] || return 0
    [[ ! -L "$prefix" ]] || return 0

    if [[ ! -e "$bin/python" && -x "$bin/python3" ]]; then
        ln -s python3 "$bin/python"
    fi
    if [[ ! -e "$bin/pip" && -x "$bin/pip3" ]]; then
        ln -s pip3 "$bin/pip"
    fi
}

install_python() {
    local version="${1:-}"
    [[ -n "$version" ]] || die "usage: envswitch fetch python [version]"
    version="$(normalize_python_version "$version")"

    case "$version" in
        3.12.12) ;;
        *) die "unsupported Python version: $version. Supported: 3.12.12" ;;
    esac

    local prefix
    prefix="$(python_home_for "$version")"

    if [[ -x "$prefix/bin/python3" ]]; then
        ensure_python_command_shims "$prefix"
        info "python-$version already installed: $prefix"
        return 0
    fi

    ensure_install_target_available "$prefix" "Python"

    local asset archive url staging
    asset="$(python_standalone_asset_name_for "$version")"
    archive="$ENVS_CACHE_HOME/downloads/$asset"
    url="$(python_standalone_url_for "$version")"
    staging="${prefix}.installing.$$"

    download_file "$url" "$archive"
    verify_sha256 "$archive" "$ENVS_PYTHON_STANDALONE_SHA256"

    rm -rf "$staging"
    mkdir -p "$(dirname -- "$prefix")" "$staging"
    info "installing Python $version from python-build-standalone"
    tar -xzf "$archive" -C "$staging" --strip-components=1

    if [[ ! -x "$staging/bin/python3" ]]; then
        rm -rf "$staging"
        die "Python archive completed but bin/python3 was not installed"
    fi

    if is_empty_dir "$prefix"; then
        rmdir "$prefix"
    fi
    mv "$staging" "$prefix"
    ensure_python_command_shims "$prefix"
    info "installed python-$version: $prefix"
}

install_toolchain() {
    local module="${1:-defaults}"
    shift || true

    load_config
    case "$module" in
        defaults | default)
            install_gcc "$ENVS_DEFAULT_GCC_VERSION"
            install_cuda "$ENVS_DEFAULT_CUDA_VERSION"
            install_python "$ENVS_DEFAULT_PYTHON_VERSION"
            ;;
        gcc)
            install_gcc "${1:-$ENVS_DEFAULT_GCC_VERSION}"
            ;;
        cuda)
            local version="$ENVS_DEFAULT_CUDA_VERSION"
            if [[ $# -gt 0 && "$1" != --* ]]; then
                version="$1"
                shift
            fi
            install_cuda "$version" "$@"
            ;;
        python)
            install_python "${1:-$ENVS_DEFAULT_PYTHON_VERSION}"
            ;;
        *) die "usage: envswitch fetch <defaults|gcc|cuda|python> [version]" ;;
    esac
}

link_path() {
    local link="$1"
    local target="$2"

    if [[ -L "$link" ]]; then
        ln -sfn "$target" "$link"
        return 0
    fi

    if is_empty_dir "$link"; then
        rmdir "$link"
    elif [[ -e "$link" ]]; then
        die "target exists and is not an empty directory or symlink: $link"
    fi

    ln -s "$target" "$link"
}

link_toolchain() {
    local module="${1:-}"
    local version="${2:-}"
    local target="${3:-}"
    [[ -n "$module" && -n "$version" && -n "$target" ]] || die "usage: envswitch link <gcc|cuda|python> <version> <path>"

    load_config

    [[ -d "$target" ]] || die "path does not exist or is not a directory: $target"
    target="$(cd -- "$target" && pwd -P)"

    case "$module" in
        gcc)
            version="$(normalize_gcc_version "$version")"
            [[ -x "$target/bin/x86_64-conda-linux-gnu-gcc" ]] || die "GCC compiler missing in: $target"
            [[ -x "$target/bin/x86_64-conda-linux-gnu-g++" ]] || die "G++ compiler missing in: $target"
            link_path "$(gcc_home_for "$version")" "$target"
            info "linked gcc-$version -> $target"
            ;;
        cuda)
            version="$(normalize_cuda_version "$version")"
            [[ -x "$target/bin/nvcc" ]] || die "CUDA nvcc missing in: $target"
            link_path "$(cuda_home_for "$version")" "$target"
            info "linked cuda-$version -> $target"
            ;;
        python)
            version="$(normalize_python_version "$version")"
            [[ -x "$target/bin/python3" ]] || die "Python executable missing in: $target"
            link_path "$(python_home_for "$version")" "$target"
            info "linked python-$version -> $target"
            ;;
        *)
            die "unknown module: $module"
            ;;
    esac

    write_config
    write_profile
}

set_default() {
    local module="${1:-}"
    local version="${2:-}"
    [[ -n "$module" && -n "$version" ]] || die "usage: envswitch default <gcc|cuda|python> <version>"

    load_config
    case "$module" in
        gcc)
            version="$(normalize_gcc_version "$version")"
            local gcc_home
            gcc_home="$(gcc_home_for "$version")"
            assert_gcc_exists "$gcc_home"
            ln -sfn "versions/gcc-$version" "$ENVS_ROOT/modules/gcc/default"
            ENVS_DEFAULT_GCC_VERSION="$version"
            ;;
        cuda)
            version="$(normalize_cuda_version "$version")"
            local cuda_home
            cuda_home="$(cuda_home_for "$version")"
            assert_cuda_exists "$cuda_home"
            ln -sfn "versions/cuda-$version" "$ENVS_ROOT/modules/cuda/default"
            ENVS_DEFAULT_CUDA_VERSION="$version"
            ;;
        python)
            version="$(normalize_python_version "$version")"
            local python_home
            python_home="$(python_home_for "$version")"
            assert_python_exists "$python_home"
            ln -sfn "versions/python-$version" "$ENVS_ROOT/modules/python/default"
            ENVS_DEFAULT_PYTHON_VERSION="$version"
            ;;
        *) die "unknown module: $module" ;;
    esac

    write_config
    write_profile
    info "default $module set to $version"
}

use_module() {
    local module="${1:-}"
    local version="${2:-}"
    [[ -n "$module" ]] || die "usage: envswitch use <gcc|cuda|python> [version]"

    load_config
    load_state
    version="${version:-$(module_default_version "$module")}"
    version="$(normalize_module_version "$module" "$version")"

    local home
    home="$(module_home_for "$module" "$version")"
    assert_module_exists "$module" "$home"

    case "$module" in
        gcc) ensure_gcc_command_shims "$home" ;;
        python) ensure_python_command_shims "$home" ;;
    esac

    module_set_version "$module" "$version"
    module_set_enabled "$module" 1
    write_config
    write_state
    write_profile
    info "using $module $version"
    if [[ "$module" == "python" && -n "${VIRTUAL_ENV:-}" ]]; then
        info "warning: VIRTUAL_ENV is active; deactivate it to use the selected base Python directly"
    fi
    warn_shell_not_refreshed
}

warn_shell_not_refreshed() {
    if [[ "${ENVS_SHELL_HOOK_ACTIVE:-}" != "1" ]]; then
        info "current shell was not updated because envswitch is running as an external command"
        info "run: source ~/.bashrc  # or open a new terminal"
    fi
}

enable_one_module() {
    local module="$1"
    local version="${2:-}"
    version="${version:-$(module_selected_version "$module")}"
    version="${version:-$(module_default_version "$module")}"
    version="$(normalize_module_version "$module" "$version")"

    local home
    home="$(module_home_for "$module" "$version")"
    assert_module_exists "$module" "$home"
    case "$module" in
        gcc) ensure_gcc_command_shims "$home" ;;
        python) ensure_python_command_shims "$home" ;;
    esac
    module_set_version "$module" "$version"
    module_set_enabled "$module" 1
}

enable_env() {
    local requested="${1:-}"
    load_config
    load_state

    if [[ -n "$requested" ]]; then
        enable_one_module "$requested"
        info "enabled $requested-$(module_selected_version "$requested")"
    else
        local targets="$ENVS_LAST_ENABLED_MODULES"
        local module version home
        local enabled=""

        if [[ -z "$targets" ]]; then
            for module in $ENVS_MODULES; do
                version="$(module_selected_version "$module")"
                version="${version:-$(module_default_version "$module")}"
                home="$(module_home_for "$module" "$version")"
                if module_is_installed "$module" "$home"; then
                    targets="${targets:+$targets }$module"
                fi
            done
        fi

        [[ -n "$targets" ]] || die "no installed modules found. Run: envswitch fetch defaults"

        for module in $ENVS_MODULES; do
            module_set_enabled "$module" 0
        done

        for module in $targets; do
            version="$(module_selected_version "$module")"
            version="${version:-$(module_default_version "$module")}"
            home="$(module_home_for "$module" "$version")"
            if module_is_installed "$module" "$home"; then
                enable_one_module "$module" "$version"
                enabled="${enabled:+$enabled }$module"
            else
                info "skipping $module-$version because it is not installed"
            fi
        done

        [[ -n "$enabled" ]] || die "none of the saved modules are installed"
        ENVS_LAST_ENABLED_MODULES="$enabled"
        info "enabled: $enabled"
    fi

    write_config
    write_state
    write_profile
    warn_shell_not_refreshed
}

disable_env() {
    local requested="${1:-}"
    load_config
    load_state

    if [[ -n "$requested" ]]; then
        case " $ENVS_MODULES " in
            *" $requested "*) ;;
            *) die "unknown module: $requested" ;;
        esac
        module_set_enabled "$requested" 0
        info "disabled $requested"
    else
        local enabled
        enabled="$(current_enabled_modules)"
        if [[ -n "$enabled" ]]; then
            ENVS_LAST_ENABLED_MODULES="$enabled"
        fi
        ENVS_GCC_ENABLED=0
        ENVS_CUDA_ENABLED=0
        ENVS_PYTHON_ENABLED=0
        info "disabled all modules"
    fi

    write_state
    write_profile
    warn_shell_not_refreshed
}

status() {
    load_config
    load_state

    printf 'EnvSwitch root: %s\n' "$ENVS_ROOT"
    printf '\n%-8s %-9s %-12s %-12s %-10s %s\n' "tool" "state" "selected" "default" "installed" "path"

    local module state version default home installed
    for module in $ENVS_MODULES; do
        version="$(module_selected_version "$module")"
        default="$(module_default_version "$module")"
        version="${version:-$default}"
        home="$(module_home_for "$module" "$version")"
        if module_enabled "$module"; then
            state="enabled"
        else
            state="disabled"
        fi
        if module_is_installed "$module" "$home"; then
            installed="yes"
        else
            installed="no"
        fi
        printf '%-8s %-9s %-12s %-12s %-10s %s\n' \
            "$module" "$state" "$version" "$default" "$installed" "$home"
    done

    printf 'profile: %s\n' "$ENVS_PROFILE_FILE"
}

main() {
    local command="${1:-help}"
    shift || true

    case "$command" in
        fetch) install_toolchain "$@" ;;
        link) link_toolchain "$@" ;;
        on) enable_env "${1:-}" ;;
        off) disable_env "${1:-}" ;;
        status) status ;;
        use) use_module "$@" ;;
        default) set_default "$@" ;;
        install-shell | install) install_shell ;;
        uninstall-shell | uninstall) uninstall_shell ;;
        help | -h | --help) usage ;;
        *) usage >&2; die "unknown command: $command" ;;
    esac
}

main "$@"
